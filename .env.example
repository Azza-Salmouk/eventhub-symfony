# ─────────────────────────────────────────────────────────────────────────────
# EventHub — Environment Variables Example
# Copy this file to .env.local and fill in your real values.
# .env.local is gitignored and will never be committed.
# ─────────────────────────────────────────────────────────────────────────────

###> symfony/framework-bundle ###
APP_ENV=dev
# Generate with: php -r "echo bin2hex(random_bytes(16));"
APP_SECRET=your_32_char_random_secret_here
###< symfony/framework-bundle ###

###> doctrine/doctrine-bundle ###
# Local dev (XAMPP):
# DATABASE_URL="mysql://root:@127.0.0.1:3306/event_project_db?serverVersion=8.0"
# Docker:
DATABASE_URL="mysql://eventhub:eventhub_pass@mysql:3306/eventhub_db?serverVersion=8.0&charset=utf8mb4"
###< doctrine/doctrine-bundle ###

###> symfony/messenger ###
MESSENGER_TRANSPORT_DSN=doctrine://default?auto_setup=0
###< symfony/messenger ###

###> symfony/mailer ###
# Option 1: Gmail SMTP
# Get App Password: Google Account → Security → 2-Step Verification → App Passwords
MAILER_DSN=smtp://YOUR_EMAIL@gmail.com:YOUR_APP_PASSWORD@smtp.gmail.com:587?encryption=tls&auth_mode=login
MAILER_FROM_EMAIL=YOUR_EMAIL@gmail.com
MAILER_FROM_NAME=EventHub

# Option 2: Mailtrap sandbox (free, no real emails sent)
# MAILER_DSN=smtp://YOUR_MAILTRAP_USER:YOUR_MAILTRAP_PASS@sandbox.smtp.mailtrap.io:2525?encryption=tls

# Option 3: Discard all emails (safe for CI/testing)
# MAILER_DSN=null://null
###< symfony/mailer ###

###> lexik/jwt-authentication-bundle ###
JWT_SECRET_KEY=%kernel.project_dir%/config/jwt/private.pem
JWT_PUBLIC_KEY=%kernel.project_dir%/config/jwt/public.pem
# Use any strong random string — must match passphrase used in generate_keys.php
JWT_PASSPHRASE=your_strong_random_passphrase_here
###< lexik/jwt-authentication-bundle ###
