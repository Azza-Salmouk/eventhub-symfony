{% extends 'base.html.twig' %}

{% block title %}Login — EventHub{% endblock %}

{% block body %}
<div class="d-flex align-items-center justify-content-center py-5"
     style="min-height:calc(100vh - 120px);background:linear-gradient(135deg,#0f0c29,#302b63,#24243e)">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-sm-10 col-md-7 col-lg-5 col-xl-4">

                {# Logo / header #}
                <div class="text-center mb-4">
                    <div class="d-inline-flex align-items-center justify-content-center rounded-3 mb-3 shadow"
                         style="width:64px;height:64px;background:linear-gradient(135deg,#6366f1,#8b5cf6)">
                        <i class="bi bi-shield-lock text-white fs-3"></i>
                    </div>
                    <h3 class="text-white fw-bold mb-1">Admin Login</h3>
                    <p class="mb-0" style="color:#a5b4fc;font-size:.9rem">Sign in to manage your events</p>
                </div>

                <div class="card border-0 shadow-lg" style="border-radius:16px">
                    <div class="card-body p-4 p-sm-5">

                        {% if error %}
                            <div class="alert alert-danger border-0 d-flex gap-2 align-items-center mb-4" style="border-radius:10px">
                                <i class="bi bi-exclamation-triangle-fill flex-shrink-0"></i>
                                <div>{{ error.messageKey|trans(error.messageData, 'security') }}</div>
                            </div>
                        {% endif %}

                        <form method="post" action="{{ path('app_login') }}" novalidate data-turbo="false">
                            <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

                            <div class="mb-4">
                                <label for="username" class="form-label fw-semibold">
                                    <i class="bi bi-person me-1 text-primary"></i>Username
                                </label>
                                <input type="text"
                                       id="username"
                                       name="_username"
                                       class="form-control form-control-lg"
                                       value="{{ last_username }}"
                                       placeholder="Enter your username"
                                       autocomplete="username"
                                       autofocus>
                            </div>

                            <div class="mb-4">
                                <label for="password" class="form-label fw-semibold">
                                    <i class="bi bi-lock me-1 text-primary"></i>Password
                                </label>
                                <div class="input-group">
                                    <input type="password"
                                           id="password"
                                           name="_password"
                                           class="form-control form-control-lg border-end-0"
                                           placeholder="Enter your password"
                                           autocomplete="current-password">
                                    <button class="btn btn-outline-secondary border-start-0"
                                            type="button"
                                            id="togglePwd"
                                            tabindex="-1">
                                        <i class="bi bi-eye" id="eyeIcon"></i>
                                    </button>
                                </div>
                            </div>

                            <div class="mb-4 form-check">
                                <input type="checkbox" class="form-check-input" id="remember" name="_remember_me">
                                <label class="form-check-label text-muted" for="remember">Remember me for 7 days</label>
                            </div>

                            <button type="submit" class="btn btn-primary btn-lg w-100 fw-bold shadow-sm">
                                <i class="bi bi-box-arrow-in-right me-2"></i>Sign In
                            </button>
                        </form>

                    </div>
                </div>

                {# Demo credentials hint #}
                <div class="mt-3 p-3 rounded-3 text-center" style="background:rgba(255,255,255,.08)">
                    <p class="mb-0 small" style="color:#a5b4fc">
                        <i class="bi bi-info-circle me-1"></i>
                        Demo: <code class="text-white">admin</code> / <code class="text-white">admin123</code>
                    </p>
                </div>

                <div class="text-center mt-3">
                    <a href="{{ path('app_home') }}" class="text-decoration-none" style="color:#a5b4fc;font-size:.9rem">
                        <i class="bi bi-arrow-left me-1"></i>Back to Home
                    </a>
                </div>

            </div>
        </div>
    </div>
</div>
{% endblock %}

{% block javascripts %}
{{ parent() }}
<script>
document.getElementById('togglePwd').addEventListener('click', function () {
    const pwd = document.getElementById('password');
    const icon = document.getElementById('eyeIcon');
    if (pwd.type === 'password') {
        pwd.type = 'text';
        icon.className = 'bi bi-eye-slash';
    } else {
        pwd.type = 'password';
        icon.className = 'bi bi-eye';
    }
});
</script>
{% endblock %}
