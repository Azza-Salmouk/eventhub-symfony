{% extends 'base.html.twig' %}

{% block title %}Events — EventHub{% endblock %}

{% block body %}
<div class="container py-5">

    {# Page header #}
    <div class="d-flex flex-wrap justify-content-between align-items-center mb-4 gap-3">
        <div>
            <h1 class="fw-bold mb-1"><i class="bi bi-grid-fill text-primary me-2"></i>All Events</h1>
            <p class="text-muted mb-0">
                {% if search or location %}
                    <span class="fw-semibold text-primary">{{ total }}</span> result(s) found
                    {% if search %} for "<em>{{ search }}</em>"{% endif %}
                    {% if location %} in "<em>{{ location }}</em>"{% endif %}
                {% else %}
                    {{ total }} event(s) available
                {% endif %}
            </p>
        </div>
    </div>

    {# Search & Filter card #}
    <div class="card mb-5 shadow-sm">
        <div class="card-body p-4">
            <form method="GET" action="{{ path('app_events') }}" id="searchForm" data-turbo="false">
                <div class="row g-3 align-items-end">
                    <div class="col-md-5">
                        <label class="form-label fw-semibold text-muted small text-uppercase ls-1">
                            <i class="bi bi-search me-1"></i>Search
                        </label>
                        <input type="text"
                               name="q"
                               id="searchInput"
                               class="form-control form-control-lg"
                               placeholder="Event name, keyword..."
                               value="{{ search }}">
                    </div>
                    <div class="col-md-4">
                        <label class="form-label fw-semibold text-muted small text-uppercase ls-1">
                            <i class="bi bi-geo-alt me-1"></i>Location
                        </label>
                        <input type="text"
                               name="location"
                               class="form-control form-control-lg"
                               placeholder="City or venue..."
                               value="{{ location }}">
                    </div>
                    <div class="col-md-3 d-flex gap-2">
                        <button type="submit" class="btn btn-primary btn-lg flex-grow-1 fw-semibold">
                            <i class="bi bi-funnel me-1"></i>Search
                        </button>
                        {% if search or location %}
                            <a href="{{ path('app_events') }}" class="btn btn-outline-secondary btn-lg" title="Clear filters">
                                <i class="bi bi-x-lg"></i>
                            </a>
                        {% endif %}
                    </div>
                </div>
            </form>
        </div>
    </div>

    {# Results #}
    {% if total == 0 %}
        <div class="text-center py-5">
            <div class="mb-4">
                <i class="bi bi-calendar-x text-muted" style="font-size:4rem"></i>
            </div>
            <h4 class="fw-bold text-muted">No events found</h4>
            <p class="text-muted mb-4">
                {% if search or location %}
                    No events match your search. Try different keywords.
                {% else %}
                    No events are available right now. Check back soon!
                {% endif %}
            </p>
            {% if search or location %}
                <a href="{{ path('app_events') }}" class="btn btn-primary px-5">
                    <i class="bi bi-arrow-left me-2"></i>View All Events
                </a>
            {% endif %}
        </div>
    {% else %}
        <div class="row g-4">
            {% for event in events %}
                <div class="col-sm-6 col-lg-4">
                    <div class="card h-100 overflow-hidden">
                        {# Event image #}
                        {% if event.image %}
                            <img src="{{ asset('uploads/events/' ~ event.image) }}"
                                 class="event-img w-100"
                                 alt="{{ event.title }}">
                        {% else %}
                            <div class="event-img-placeholder"
                                 style="background: linear-gradient(135deg,
                                    {{ ['#6366f1','#8b5cf6','#ec4899','#f59e0b','#10b981','#3b82f6'][loop.index0 % 6] }},
                                    {{ ['#4f46e5','#7c3aed','#db2777','#d97706','#059669','#2563eb'][loop.index0 % 6] }});">
                                <i class="bi bi-calendar-event text-white" style="font-size:3.5rem;opacity:.8"></i>
                            </div>
                        {% endif %}

                        <div class="card-body d-flex flex-column p-4">
                            {# Badges row #}
                            <div class="d-flex justify-content-between align-items-center mb-3">
                                <span class="badge bg-primary bg-opacity-10 text-primary rounded-pill px-3 py-1">
                                    <i class="bi bi-geo-alt me-1"></i>{{ event.location }}
                                </span>
                                {% if event.availableSeats > 0 %}
                                    <span class="badge badge-available rounded-pill px-3 py-1">
                                        {{ event.availableSeats }} left
                                    </span>
                                {% else %}
                                    <span class="badge badge-full rounded-pill px-3 py-1">Sold Out</span>
                                {% endif %}
                            </div>

                            <h5 class="card-title fw-bold mb-2">{{ event.title }}</h5>
                            <p class="card-text text-muted small flex-grow-1 lh-base">
                                {{ event.description|slice(0, 100) }}{% if event.description|length > 100 %}…{% endif %}
                            </p>

                            <div class="d-flex align-items-center text-muted small mb-3 mt-2 gap-3">
                                <span><i class="bi bi-calendar3 me-1"></i>{{ event.date|date('M j, Y') }}</span>
                                <span><i class="bi bi-clock me-1"></i>{{ event.date|date('g:i A') }}</span>
                            </div>

                            {# Availability mini-bar #}
                            {% set pct = event.seats > 0 ? ((event.reservations|length / event.seats) * 100)|round : 0 %}
                            <div class="progress mb-3" style="height:4px">
                                <div class="progress-bar {{ pct > 80 ? 'bg-danger' : (pct > 50 ? 'bg-warning' : 'bg-success') }}"
                                     style="width:{{ pct }}%"></div>
                            </div>

                            <div class="d-flex gap-2">
                                <a href="{{ path('app_event_show', {id: event.id}) }}"
                                   class="btn btn-outline-primary btn-sm flex-grow-1 fw-semibold">
                                    <i class="bi bi-eye me-1"></i>Details
                                </a>
                                {% if event.availableSeats > 0 %}
                                    <a href="{{ path('app_reserve', {id: event.id}) }}"
                                       class="btn btn-primary btn-sm flex-grow-1 fw-semibold">
                                        <i class="bi bi-ticket-perforated me-1"></i>Reserve
                                    </a>
                                {% else %}
                                    <button class="btn btn-secondary btn-sm flex-grow-1" disabled>Sold Out</button>
                                {% endif %}
                            </div>
                        </div>
                    </div>
                </div>
            {% endfor %}
        </div>

        {# Pagination #}
        {% if totalPages > 1 %}
            <nav class="mt-5 d-flex justify-content-center" aria-label="Events pagination">
                <ul class="pagination gap-1">
                    <li class="page-item {{ currentPage == 1 ? 'disabled' : '' }}">
                        <a class="page-link px-3"
                           href="{{ path('app_events', {page: currentPage - 1, q: search, location: location}) }}">
                            <i class="bi bi-chevron-left"></i>
                        </a>
                    </li>
                    {% for p in 1..totalPages %}
                        <li class="page-item {{ p == currentPage ? 'active' : '' }}">
                            <a class="page-link px-3"
                               href="{{ path('app_events', {page: p, q: search, location: location}) }}">{{ p }}</a>
                        </li>
                    {% endfor %}
                    <li class="page-item {{ currentPage == totalPages ? 'disabled' : '' }}">
                        <a class="page-link px-3"
                           href="{{ path('app_events', {page: currentPage + 1, q: search, location: location}) }}">
                            <i class="bi bi-chevron-right"></i>
                        </a>
                    </li>
                </ul>
            </nav>
        {% endif %}
    {% endif %}

</div>
{% endblock %}
