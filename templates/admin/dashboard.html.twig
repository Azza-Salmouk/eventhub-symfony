{% extends 'admin/base.html.twig' %}

{% block title %}Dashboard — Admin{% endblock %}

{% block admin_content %}

<div class="d-flex flex-wrap justify-content-between align-items-center mb-5 gap-3">
    <div>
        <h2 class="fw-bold mb-1"><i class="bi bi-speedometer2 text-primary me-2"></i>Dashboard</h2>
        <p class="text-muted mb-0">Welcome back, <strong>{{ app.user.userIdentifier }}</strong></p>
    </div>
    <div class="text-muted small">
        <i class="bi bi-calendar3 me-1"></i>{{ "now"|date("l, F j Y") }}
    </div>
</div>

{# Stats row #}
<div class="row g-4 mb-5">
    <div class="col-sm-6 col-xl-3">
        <div class="card border-0 shadow-sm h-100" style="border-left:4px solid #6366f1 !important">
            <div class="card-body d-flex align-items-center gap-4 p-4">
                <div class="rounded-3 d-flex align-items-center justify-content-center flex-shrink-0"
                     style="width:56px;height:56px;background:#ede9fe">
                    <i class="bi bi-calendar-event" style="font-size:1.6rem;color:#6366f1"></i>
                </div>
                <div>
                    <div class="fs-2 fw-bold text-primary lh-1 mb-1">{{ totalEvents }}</div>
                    <div class="text-muted small fw-semibold">Total Events</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="card border-0 shadow-sm h-100" style="border-left:4px solid #10b981 !important">
            <div class="card-body d-flex align-items-center gap-4 p-4">
                <div class="rounded-3 d-flex align-items-center justify-content-center flex-shrink-0"
                     style="width:56px;height:56px;background:#d1fae5">
                    <i class="bi bi-ticket-perforated" style="font-size:1.6rem;color:#10b981"></i>
                </div>
                <div>
                    <div class="fs-2 fw-bold lh-1 mb-1" style="color:#10b981">{{ totalReservations }}</div>
                    <div class="text-muted small fw-semibold">Total Reservations</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="card border-0 shadow-sm h-100" style="border-left:4px solid #f59e0b !important">
            <div class="card-body d-flex align-items-center gap-4 p-4">
                <div class="rounded-3 d-flex align-items-center justify-content-center flex-shrink-0"
                     style="width:56px;height:56px;background:#fef3c7">
                    <i class="bi bi-lightning-fill" style="font-size:1.6rem;color:#f59e0b"></i>
                </div>
                <div>
                    <div class="fs-2 fw-bold lh-1 mb-1" style="color:#f59e0b">{{ upcomingEvents|length }}</div>
                    <div class="text-muted small fw-semibold">Upcoming Events</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="card border-0 shadow-sm h-100" style="border-left:4px solid #8b5cf6 !important">
            <div class="card-body d-flex align-items-center gap-4 p-4">
                <div class="rounded-3 d-flex align-items-center justify-content-center flex-shrink-0"
                     style="width:56px;height:56px;background:#ede9fe">
                    <i class="bi bi-graph-up-arrow" style="font-size:1.6rem;color:#8b5cf6"></i>
                </div>
                <div>
                    <div class="fs-2 fw-bold lh-1 mb-1" style="color:#8b5cf6">
                        {{ totalEvents > 0 ? (totalReservations / totalEvents)|round(1) : 0 }}
                    </div>
                    <div class="text-muted small fw-semibold">Avg. per Event</div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row g-4">

    {# Recent Reservations #}
    <div class="col-lg-7">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-header bg-white border-0 d-flex justify-content-between align-items-center py-3 px-4">
                <h5 class="mb-0 fw-bold">
                    <i class="bi bi-clock-history text-primary me-2"></i>Recent Reservations
                </h5>
                <a href="{{ path('app_admin_reservations') }}" class="btn btn-sm btn-outline-primary">
                    View All <i class="bi bi-arrow-right ms-1"></i>
                </a>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th class="ps-4 py-3 small text-muted fw-semibold">Guest</th>
                                <th class="py-3 small text-muted fw-semibold">Event</th>
                                <th class="pe-4 py-3 small text-muted fw-semibold">Date</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for r in recentReservations %}
                                <tr>
                                    <td class="ps-4">
                                        <div class="fw-semibold small">{{ r.name }}</div>
                                        <div class="text-muted" style="font-size:.75rem">{{ r.email }}</div>
                                    </td>
                                    <td>
                                        <span class="badge bg-primary bg-opacity-10 text-primary rounded-pill px-3">
                                            {{ r.event.title|slice(0,25) }}{% if r.event.title|length > 25 %}…{% endif %}
                                        </span>
                                    </td>
                                    <td class="pe-4 text-muted small">{{ r.createdAt|date('M j, Y') }}</td>
                                </tr>
                            {% else %}
                                <tr>
                                    <td colspan="3" class="text-center text-muted py-4 small">
                                        No reservations yet.
                                    </td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    {# Upcoming Events #}
    <div class="col-lg-5">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-header bg-white border-0 d-flex justify-content-between align-items-center py-3 px-4">
                <h5 class="mb-0 fw-bold">
                    <i class="bi bi-calendar3 text-warning me-2"></i>Upcoming Events
                </h5>
                <a href="{{ path('app_admin_events') }}" class="btn btn-sm btn-outline-primary">
                    Manage <i class="bi bi-arrow-right ms-1"></i>
                </a>
            </div>
            <ul class="list-group list-group-flush">
                {% for event in upcomingEvents %}
                    <li class="list-group-item border-0 px-4 py-3">
                        <div class="d-flex justify-content-between align-items-center">
                            <div class="flex-grow-1 me-3">
                                <div class="fw-semibold small text-truncate" style="max-width:180px">{{ event.title }}</div>
                                <div class="text-muted" style="font-size:.72rem">
                                    <i class="bi bi-calendar3 me-1"></i>{{ event.date|date('M j') }}
                                    &nbsp;·&nbsp;
                                    <i class="bi bi-geo-alt me-1"></i>{{ event.location }}
                                </div>
                            </div>
                            <span class="badge {{ event.availableSeats > 0 ? 'badge-available' : 'badge-full' }} rounded-pill px-2 flex-shrink-0">
                                {{ event.availableSeats }} left
                            </span>
                        </div>
                    </li>
                {% else %}
                    <li class="list-group-item border-0 text-center text-muted py-4 small">
                        No upcoming events.
                    </li>
                {% endfor %}
            </ul>
        </div>
    </div>

</div>
{% endblock %}
