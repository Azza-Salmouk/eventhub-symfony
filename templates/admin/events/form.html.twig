{% extends 'admin/base.html.twig' %}

{% block title %}{{ title }} — Admin{% endblock %}

{% block admin_content %}

<div class="d-flex align-items-center gap-3 mb-4">
    <a href="{{ path('app_admin_events') }}" class="btn btn-outline-secondary btn-sm rounded-circle" style="width:36px;height:36px;padding:0;line-height:34px;text-align:center">
        <i class="bi bi-arrow-left"></i>
    </a>
    <div>
        <h2 class="fw-bold mb-0">{{ title }}</h2>
        <p class="text-muted mb-0 small">Fill in the details below and save.</p>
    </div>
</div>

<div class="row g-4">
    <div class="col-xl-8">
        <div class="card shadow-sm border-0">
            <div class="card-body p-4">

                {{ form_start(form, {attr: {
                    enctype: 'multipart/form-data',
                    novalidate: 'novalidate',
                    id: 'eventForm',
                    'data-turbo': 'false'
                }}) }}

                <div class="row g-4">

                    {# Title #}
                    <div class="col-12">
                        <label class="form-label fw-semibold" for="{{ form.title.vars.id }}">
                            {{ form.title.vars.label }} <span class="text-danger">*</span>
                        </label>
                        {{ form_widget(form.title, {attr: {
                            class: 'form-control form-control-lg' ~ (form.title.vars.errors|length > 0 ? ' is-invalid' : ''),
                            id: form.title.vars.id
                        }}) }}
                        {% if form.title.vars.errors|length > 0 %}
                            <div class="invalid-feedback d-block">
                                {% for error in form.title.vars.errors %}{{ error.message }}{% endfor %}
                            </div>
                        {% endif %}
                    </div>

                    {# Description #}
                    <div class="col-12">
                        <label class="form-label fw-semibold" for="{{ form.description.vars.id }}">
                            {{ form.description.vars.label }} <span class="text-danger">*</span>
                        </label>
                        {{ form_widget(form.description, {attr: {
                            class: 'form-control' ~ (form.description.vars.errors|length > 0 ? ' is-invalid' : ''),
                            rows: 5,
                            id: form.description.vars.id
                        }}) }}
                        {% if form.description.vars.errors|length > 0 %}
                            <div class="invalid-feedback d-block">
                                {% for error in form.description.vars.errors %}{{ error.message }}{% endfor %}
                            </div>
                        {% endif %}
                    </div>

                    {# Date #}
                    <div class="col-md-6">
                        <label class="form-label fw-semibold" for="{{ form.date.vars.id }}">
                            {{ form.date.vars.label }} <span class="text-danger">*</span>
                        </label>
                        {{ form_widget(form.date, {attr: {
                            class: 'form-control' ~ (form.date.vars.errors|length > 0 ? ' is-invalid' : ''),
                            id: form.date.vars.id
                        }}) }}
                        {% if form.date.vars.errors|length > 0 %}
                            <div class="invalid-feedback d-block">
                                {% for error in form.date.vars.errors %}{{ error.message }}{% endfor %}
                            </div>
                        {% endif %}
                    </div>

                    {# Location #}
                    <div class="col-md-6">
                        <label class="form-label fw-semibold" for="{{ form.location.vars.id }}">
                            {{ form.location.vars.label }} <span class="text-danger">*</span>
                        </label>
                        {{ form_widget(form.location, {attr: {
                            class: 'form-control' ~ (form.location.vars.errors|length > 0 ? ' is-invalid' : ''),
                            id: form.location.vars.id
                        }}) }}
                        {% if form.location.vars.errors|length > 0 %}
                            <div class="invalid-feedback d-block">
                                {% for error in form.location.vars.errors %}{{ error.message }}{% endfor %}
                            </div>
                        {% endif %}
                    </div>

                    {# Seats #}
                    <div class="col-md-4">
                        <label class="form-label fw-semibold" for="{{ form.seats.vars.id }}">
                            {{ form.seats.vars.label }} <span class="text-danger">*</span>
                        </label>
                        {{ form_widget(form.seats, {attr: {
                            class: 'form-control' ~ (form.seats.vars.errors|length > 0 ? ' is-invalid' : ''),
                            id: form.seats.vars.id
                        }}) }}
                        {% if form.seats.vars.errors|length > 0 %}
                            <div class="invalid-feedback d-block">
                                {% for error in form.seats.vars.errors %}{{ error.message }}{% endfor %}
                            </div>
                        {% endif %}
                    </div>

                    {# Image upload #}
                    <div class="col-md-8">
                        <label class="form-label fw-semibold" for="{{ form.imageFile.vars.id }}">
                            {{ form.imageFile.vars.label }}
                        </label>
                        {{ form_widget(form.imageFile, {attr: {
                            class: 'form-control' ~ (form.imageFile.vars.errors|length > 0 ? ' is-invalid' : ''),
                            id: form.imageFile.vars.id
                        }}) }}
                        {% if form.imageFile.vars.errors|length > 0 %}
                            <div class="invalid-feedback d-block">
                                {% for error in form.imageFile.vars.errors %}{{ error.message }}{% endfor %}
                            </div>
                        {% endif %}
                        {% if event.image %}
                            <div class="mt-3 d-flex align-items-center gap-3 p-3 bg-light rounded-3">
                                <img src="{{ asset('uploads/events/' ~ event.image) }}"
                                     class="rounded-2 shadow-sm"
                                     style="width:60px;height:60px;object-fit:cover"
                                     alt="Current image">
                                <div>
                                    <div class="fw-semibold small">Current image</div>
                                    <div class="text-muted" style="font-size:.75rem">Upload a new file to replace it</div>
                                </div>
                            </div>
                        {% endif %}
                    </div>

                </div>{# /row #}

                <hr class="my-4">

                <div class="d-flex gap-3">
                    <button type="submit" class="btn btn-primary btn-lg px-5 fw-bold shadow-sm">
                        <i class="bi bi-check-lg me-2"></i>{{ event.id ? 'Update Event' : 'Create Event' }}
                    </button>
                    <a href="{{ path('app_admin_events') }}" class="btn btn-outline-secondary btn-lg px-4">
                        Cancel
                    </a>
                </div>

                {{ form_end(form) }}

            </div>
        </div>
    </div>

    {# Sidebar tips #}
    <div class="col-xl-4">
        <div class="card border-0 shadow-sm mb-4">
            <div class="card-body p-4">
                <h6 class="fw-bold mb-3">
                    <i class="bi bi-lightbulb-fill text-warning me-2"></i>Tips
                </h6>
                <ul class="list-unstyled small text-muted mb-0">
                    <li class="mb-2 d-flex gap-2"><i class="bi bi-check2 text-success mt-1"></i>Use a clear, descriptive title</li>
                    <li class="mb-2 d-flex gap-2"><i class="bi bi-check2 text-success mt-1"></i>Set a realistic seat count</li>
                    <li class="mb-2 d-flex gap-2"><i class="bi bi-check2 text-success mt-1"></i>Upload a 16:9 image for best results</li>
                    <li class="d-flex gap-2"><i class="bi bi-check2 text-success mt-1"></i>Max image size: 2MB (JPG, PNG, WEBP)</li>
                </ul>
            </div>
        </div>

        {% if event.id %}
        <div class="card border-0 shadow-sm border-danger border-opacity-25">
            <div class="card-body p-4">
                <h6 class="fw-bold mb-3 text-danger">
                    <i class="bi bi-trash me-2"></i>Danger Zone
                </h6>
                <p class="small text-muted mb-3">Deleting this event will also remove all its reservations.</p>
                <button type="button" class="btn btn-outline-danger btn-sm w-100"
                        data-bs-toggle="modal" data-bs-target="#deleteModal">
                    <i class="bi bi-trash me-1"></i>Delete this event
                </button>
            </div>
        </div>

        {# Delete modal #}
        <div class="modal fade" id="deleteModal" tabindex="-1">
            <div class="modal-dialog modal-sm">
                <div class="modal-content border-0 shadow">
                    <div class="modal-header border-0 pb-0">
                        <h6 class="modal-title fw-bold text-danger"><i class="bi bi-exclamation-triangle me-2"></i>Delete Event</h6>
                        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                    </div>
                    <div class="modal-body small text-muted">
                        Are you sure you want to delete <strong>{{ event.title }}</strong>?
                        This action cannot be undone.
                    </div>
                    <div class="modal-footer border-0 pt-0">
                        <button type="button" class="btn btn-sm btn-secondary" data-bs-dismiss="modal">Cancel</button>
                        <form method="post" action="{{ path('app_admin_event_delete', {id: event.id}) }}" data-turbo="false">
                            <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ event.id) }}">
                            <button type="submit" class="btn btn-sm btn-danger">Delete</button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
        {% endif %}
    </div>

</div>
{% endblock %}
