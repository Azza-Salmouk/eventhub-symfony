{% extends 'admin/base.html.twig' %}

{% block title %}Manage Events — Admin{% endblock %}

{% block admin_content %}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="fw-bold mb-1"><i class="bi bi-calendar-event text-primary me-2"></i>Events</h2>
        <p class="text-muted mb-0 small">{{ events|length }} event(s) total</p>
    </div>
    <a href="{{ path('app_admin_event_new') }}" class="btn btn-primary fw-semibold shadow-sm">
        <i class="bi bi-plus-lg me-1"></i>New Event
    </a>
</div>

{% if events|length == 0 %}
    <div class="card border-0 shadow-sm">
        <div class="card-body text-center py-5">
            <i class="bi bi-calendar-x text-muted" style="font-size:3rem"></i>
            <h5 class="mt-3 text-muted">No events yet</h5>
            <a href="{{ path('app_admin_event_new') }}" class="btn btn-primary mt-2">
                <i class="bi bi-plus-lg me-1"></i>Create your first event
            </a>
        </div>
    </div>
{% else %}
    <div class="card border-0 shadow-sm">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead>
                        <tr class="border-bottom">
                            <th class="ps-4 py-3 text-muted small fw-semibold text-uppercase">#</th>
                            <th class="py-3 text-muted small fw-semibold text-uppercase">Event</th>
                            <th class="py-3 text-muted small fw-semibold text-uppercase">Date</th>
                            <th class="py-3 text-muted small fw-semibold text-uppercase">Location</th>
                            <th class="py-3 text-muted small fw-semibold text-uppercase">Seats</th>
                            <th class="py-3 text-muted small fw-semibold text-uppercase">Reservations</th>
                            <th class="py-3 text-muted small fw-semibold text-uppercase">Status</th>
                            <th class="pe-4 py-3 text-end text-muted small fw-semibold text-uppercase">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for event in events %}
                            <tr>
                                <td class="ps-4 text-muted small">{{ event.id }}</td>
                                <td>
                                    <div class="d-flex align-items-center gap-3">
                                        {% if event.image %}
                                            <img src="{{ asset('uploads/events/' ~ event.image) }}"
                                                 class="rounded-2 flex-shrink-0"
                                                 style="width:44px;height:44px;object-fit:cover"
                                                 alt="">
                                        {% else %}
                                            <div class="rounded-2 flex-shrink-0 d-flex align-items-center justify-content-center"
                                                 style="width:44px;height:44px;background:linear-gradient(135deg,#6366f1,#8b5cf6)">
                                                <i class="bi bi-calendar-event text-white small"></i>
                                            </div>
                                        {% endif %}
                                        <div>
                                            <div class="fw-semibold">{{ event.title }}</div>
                                            <div class="text-muted" style="font-size:.75rem">
                                                {{ event.description|slice(0,50) }}…
                                            </div>
                                        </div>
                                    </div>
                                </td>
                                <td>
                                    <div class="fw-semibold small">{{ event.date|date('M j, Y') }}</div>
                                    <div class="text-muted" style="font-size:.75rem">{{ event.date|date('g:i A') }}</div>
                                </td>
                                <td class="small">
                                    <i class="bi bi-geo-alt text-muted me-1"></i>{{ event.location }}
                                </td>
                                <td class="small fw-semibold">{{ event.seats }}</td>
                                <td>
                                    <div class="d-flex align-items-center gap-2">
                                        <span class="fw-semibold small">{{ event.reservations|length }}</span>
                                        <div class="progress flex-grow-1" style="height:5px;min-width:60px">
                                            {% set pct = event.seats > 0 ? ((event.reservations|length / event.seats) * 100)|round : 0 %}
                                            <div class="progress-bar {{ pct > 80 ? 'bg-danger' : (pct > 50 ? 'bg-warning' : 'bg-success') }}"
                                                 style="width:{{ pct }}%"></div>
                                        </div>
                                    </div>
                                </td>
                                <td>
                                    {% if event.availableSeats > 0 %}
                                        <span class="badge badge-available rounded-pill px-3">Open</span>
                                    {% else %}
                                        <span class="badge badge-full rounded-pill px-3">Full</span>
                                    {% endif %}
                                </td>
                                <td class="pe-4 text-end">
                                    <div class="btn-group btn-group-sm">
                                        <a href="{{ path('app_event_show', {id: event.id}) }}"
                                           class="btn btn-outline-secondary"
                                           title="View public page"
                                           target="_blank">
                                            <i class="bi bi-eye"></i>
                                        </a>
                                        <a href="{{ path('app_admin_event_edit', {id: event.id}) }}"
                                           class="btn btn-outline-primary"
                                           title="Edit">
                                            <i class="bi bi-pencil"></i>
                                        </a>
                                        <button type="button"
                                                class="btn btn-outline-danger"
                                                title="Delete"
                                                data-bs-toggle="modal"
                                                data-bs-target="#del{{ event.id }}">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </div>

                                    {# Delete confirmation modal #}
                                    <div class="modal fade" id="del{{ event.id }}" tabindex="-1" aria-hidden="true">
                                        <div class="modal-dialog modal-sm modal-dialog-centered">
                                            <div class="modal-content border-0 shadow-lg">
                                                <div class="modal-body text-center p-4">
                                                    <div class="bg-danger bg-opacity-10 rounded-circle d-inline-flex p-3 mb-3">
                                                        <i class="bi bi-trash text-danger fs-4"></i>
                                                    </div>
                                                    <h6 class="fw-bold mb-2">Delete Event?</h6>
                                                    <p class="text-muted small mb-4">
                                                        "<strong>{{ event.title }}</strong>" and all its reservations will be permanently deleted.
                                                    </p>
                                                    <div class="d-flex gap-2 justify-content-center">
                                                        <button type="button" class="btn btn-sm btn-secondary px-4" data-bs-dismiss="modal">
                                                            Cancel
                                                        </button>
                                                        <form method="post" action="{{ path('app_admin_event_delete', {id: event.id}) }}" data-turbo="false">
                                                            <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ event.id) }}">
                                                            <button type="submit" class="btn btn-sm btn-danger px-4">
                                                                <i class="bi bi-trash me-1"></i>Delete
                                                            </button>
                                                        </form>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>
{% endif %}

{% endblock %}
