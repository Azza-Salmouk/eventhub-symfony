{% extends 'admin/base.html.twig' %}

{% block title %}Reservations — Admin{% endblock %}

{% block admin_content %}

<div class="d-flex flex-wrap justify-content-between align-items-center mb-4 gap-3">
    <div>
        <h2 class="fw-bold mb-1"><i class="bi bi-ticket-perforated text-primary me-2"></i>Reservations</h2>
        <p class="text-muted mb-0 small">{{ reservations|length }} reservation(s)
            {% if selectedEvent > 0 %} for selected event{% endif %}
        </p>
    </div>
    <span class="badge bg-primary fs-6 px-3 py-2">{{ reservations|length }} total</span>
</div>

{# Filter by event #}
<div class="card border-0 shadow-sm mb-4">
    <div class="card-body p-3">
        <form method="GET" action="{{ path('app_admin_reservations') }}" class="d-flex gap-3 align-items-end flex-wrap" data-turbo="false">
            <div class="flex-grow-1" style="min-width:200px">
                <label class="form-label fw-semibold small text-muted text-uppercase mb-1">
                    <i class="bi bi-funnel me-1"></i>Filter by Event
                </label>
                <select name="event" class="form-select" onchange="this.form.submit()">
                    <option value="0">— All Events —</option>
                    {% for event in events %}
                        <option value="{{ event.id }}" {{ selectedEvent == event.id ? 'selected' : '' }}>
                            {{ event.title }} ({{ event.date|date('M j, Y') }})
                        </option>
                    {% endfor %}
                </select>
            </div>
            {% if selectedEvent > 0 %}
                <a href="{{ path('app_admin_reservations') }}" class="btn btn-outline-secondary">
                    <i class="bi bi-x-lg me-1"></i>Clear
                </a>
            {% endif %}
        </form>
    </div>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead>
                    <tr class="border-bottom">
                        <th class="ps-4 py-3 text-muted small fw-semibold text-uppercase">#</th>
                        <th class="py-3 text-muted small fw-semibold text-uppercase">Guest</th>
                        <th class="py-3 text-muted small fw-semibold text-uppercase">Contact</th>
                        <th class="py-3 text-muted small fw-semibold text-uppercase">Event</th>
                        <th class="py-3 text-muted small fw-semibold text-uppercase">Event Date</th>
                        <th class="pe-4 py-3 text-muted small fw-semibold text-uppercase">Reserved On</th>
                    </tr>
                </thead>
                <tbody>
                    {% for r in reservations %}
                        <tr>
                            <td class="ps-4 text-muted small">{{ r.id }}</td>
                            <td>
                                <div class="d-flex align-items-center gap-3">
                                    <div class="bg-primary bg-opacity-10 rounded-circle d-flex align-items-center justify-content-center fw-bold text-primary flex-shrink-0"
                                         style="width:38px;height:38px;font-size:.85rem">
                                        {{ r.name|slice(0,1)|upper }}
                                    </div>
                                    <div class="fw-semibold">{{ r.name }}</div>
                                </div>
                            </td>
                            <td>
                                <div class="small">
                                    <i class="bi bi-envelope text-muted me-1"></i>
                                    <a href="mailto:{{ r.email }}" class="text-decoration-none text-dark">{{ r.email }}</a>
                                </div>
                                <div class="small text-muted">
                                    <i class="bi bi-telephone me-1"></i>{{ r.phone }}
                                </div>
                            </td>
                            <td>
                                <a href="{{ path('app_event_show', {id: r.event.id}) }}"
                                   class="badge bg-primary bg-opacity-10 text-primary text-decoration-none px-3 py-2 rounded-pill"
                                   target="_blank">
                                    {{ r.event.title }}
                                </a>
                            </td>
                            <td class="small text-muted">{{ r.event.date|date('M j, Y') }}</td>
                            <td class="pe-4 small text-muted">{{ r.createdAt|date('M j, Y · g:i A') }}</td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="6" class="text-center py-5">
                                <i class="bi bi-ticket-perforated text-muted" style="font-size:2.5rem"></i>
                                <p class="text-muted mt-3 mb-0">No reservations found.</p>
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
</div>

{% endblock %}
