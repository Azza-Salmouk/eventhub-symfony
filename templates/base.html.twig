<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}EventHub{% endblock %}</title>
    <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22><text y=%221.2em%22 font-size=%2296%22>🎫</text></svg>">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
    {% block stylesheets %}{% endblock %}
    <style>
        :root {
            --bs-primary: #6366f1;
            --primary: #6366f1;
            --primary-dark: #4f46e5;
        }
        body { font-family: 'Segoe UI', system-ui, sans-serif; background: #ffffff; color: #1e293b; }
        /* Navbar */
        .navbar { background: linear-gradient(135deg, #0f0c29, #302b63, #24243e) !important; box-shadow: 0 2px 20px rgba(0,0,0,.3); }
        .navbar-brand { font-weight: 800; font-size: 1.35rem; letter-spacing: -.5px; }
        .navbar .nav-link { font-weight: 500; transition: color .2s; }
        /* Buttons */
        .btn-primary { background: #6366f1; border-color: #6366f1; font-weight: 600; }
        .btn-primary:hover, .btn-primary:focus { background: #4f46e5; border-color: #4f46e5; }
        .btn-outline-primary { color: #6366f1; border-color: #6366f1; font-weight: 600; }
        .btn-outline-primary:hover { background: #6366f1; border-color: #6366f1; }
        /* Cards */
        .card { border: none; border-radius: 12px; box-shadow: 0 1px 4px rgba(0,0,0,.07); transition: transform .2s ease, box-shadow .2s ease; }
        .card:hover { transform: translateY(-4px); box-shadow: 0 12px 30px rgba(99,102,241,.15); }
        /* Event image placeholder */
        .event-img { height: 210px; object-fit: cover; border-radius: 12px 12px 0 0; }
        .event-img-placeholder { height: 210px; border-radius: 12px 12px 0 0; display: flex; align-items: center; justify-content: center; }
        /* Badges */
        .badge-available { background: #dcfce7; color: #15803d; font-weight: 600; }
        .badge-full { background: #fee2e2; color: #b91c1c; font-weight: 600; }
        /* Hero */
        .hero { background: linear-gradient(135deg, #0f0c29 0%, #302b63 50%, #6366f1 100%); position: relative; overflow: hidden; }
        .hero::before { content: ''; position: absolute; inset: 0; background: url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23ffffff' fill-opacity='0.03'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E"); }
        /* Footer */
        footer { background: linear-gradient(135deg, #0f0c29, #302b63); color: #a5b4fc; }
        /* Stat cards */
        .stat-card { border-radius: 12px; border: none; }
        /* Form validation */
        .form-control.is-invalid, .form-select.is-invalid { border-color: #dc3545; }
        .invalid-feedback { display: block; }
        /* Sidebar */
        .admin-sidebar { background: linear-gradient(180deg, #0f0c29 0%, #1e1b4b 100%); min-height: calc(100vh - 60px); }
        .admin-sidebar .nav-link { color: #a5b4fc; border-radius: 8px; padding: .6rem 1rem; font-weight: 500; transition: all .2s; }
        .admin-sidebar .nav-link:hover, .admin-sidebar .nav-link.active { background: rgba(99,102,241,.25); color: #fff; }
        .admin-sidebar .nav-link.active { background: #6366f1; color: #fff; }
        /* Pagination */
        .page-link { color: #6366f1; border-radius: 8px !important; margin: 0 2px; }
        .page-item.active .page-link { background: #6366f1; border-color: #6366f1; }
        /* Alerts */
        .alert { border-radius: 10px; border: none; }
        /* Progress */
        .progress { border-radius: 99px; }
        /* Table */
        .table > :not(caption) > * > * { padding: .85rem 1rem; }
    </style>
    {# Importmap loads Stimulus + CSRF controller — required for form submissions #}
    {% block importmap %}{{ importmap('app') }}{% endblock %}
</head>
<body style="background-color:white !important;">

<nav class="navbar navbar-expand-lg navbar-dark sticky-top">
    <div class="container">
        <a class="navbar-brand text-white" href="{{ path('app_home') }}">
            <i class="bi bi-calendar-event-fill me-2 text-indigo-300" style="color:#a5b4fc"></i>EventHub
        </a>
        <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
            <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="navbarNav">
            <ul class="navbar-nav me-auto gap-1">
                <li class="nav-item">
                    <a class="nav-link {{ app.request.attributes.get('_route') == 'app_home' ? 'active' : '' }}"
                       href="{{ path('app_home') }}"><i class="bi bi-house me-1"></i>Home</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link {{ app.request.attributes.get('_route') starts with 'app_event' ? 'active' : '' }}"
                       href="{{ path('app_events') }}"><i class="bi bi-grid me-1"></i>Events</a>
                </li>
            </ul>
            <ul class="navbar-nav align-items-center gap-2">
                {% if is_granted('ROLE_ADMIN') %}
                    <li class="nav-item">
                        <a class="nav-link {{ app.request.attributes.get('_route') starts with 'app_admin' ? 'active' : '' }}"
                           href="{{ path('app_admin_dashboard') }}">
                            <i class="bi bi-speedometer2 me-1"></i>Admin Dashboard
                        </a>
                    </li>
                {% endif %}
                {% if app.user %}
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle d-flex align-items-center gap-2" href="#" data-bs-toggle="dropdown">
                            <span class="bg-primary rounded-circle d-inline-flex align-items-center justify-content-center text-white fw-bold"
                                  style="width:30px;height:30px;font-size:.75rem">
                                {{ app.user.userIdentifier|slice(0,1)|upper }}
                            </span>
                            {{ app.user.userIdentifier }}
                        </a>
                        <ul class="dropdown-menu dropdown-menu-end shadow border-0">
                            {% if is_granted('ROLE_ADMIN') %}
                                <li><a class="dropdown-item" href="{{ path('app_admin_dashboard') }}"><i class="bi bi-speedometer2 me-2 text-primary"></i>Dashboard</a></li>
                                <li><hr class="dropdown-divider"></li>
                            {% endif %}
                            <li>
                                <a class="dropdown-item text-danger" href="{{ path('app_logout') }}">
                                    <i class="bi bi-box-arrow-right me-2"></i>Logout
                                </a>
                            </li>
                        </ul>
                    </li>
                {% else %}
                    <li class="nav-item">
                        <a class="btn btn-outline-light btn-sm px-4 fw-semibold" href="{{ path('app_admin_login') }}">
                            <i class="bi bi-shield-lock me-1"></i>Admin
                        </a>
                    </li>
                {% endif %}
            </ul>
        </div>
    </div>
</nav>

<main>
    {% if app.flashes|length > 0 %}
    <div class="container mt-3">
        {% for type, messages in app.flashes %}
            {% for message in messages %}
                <div class="alert alert-{{ type == 'success' ? 'success' : (type == 'warning' ? 'warning' : (type == 'error' ? 'danger' : type)) }} alert-dismissible fade show shadow-sm d-flex align-items-center gap-2" role="alert">
                    <i class="bi bi-{{ type == 'success' ? 'check-circle-fill' : (type == 'warning' ? 'exclamation-triangle-fill' : 'x-circle-fill') }} flex-shrink-0"></i>
                    <div>{{ message }}</div>
                    <button type="button" class="btn-close ms-auto" data-bs-dismiss="alert"></button>
                </div>
            {% endfor %}
        {% endfor %}
    </div>
    {% endif %}
    {% block body %}{% endblock %}
</main>

<footer class="mt-5" style="background:linear-gradient(135deg,#0f0c29,#302b63);color:#a5b4fc">
    <div class="container py-5">
        <div class="row g-4">
            {# Brand column #}
            <div class="col-lg-4 col-md-6">
                <div class="fw-bold text-white fs-4 mb-2">
                    <i class="bi bi-calendar-event-fill me-2" style="color:#a5b4fc"></i>EventHub
                </div>
                <p class="mb-3" style="font-size:.9rem;line-height:1.7">
                    Discover, reserve, and experience amazing events. Your next unforgettable moment is just a click away.
                </p>
                <div class="d-flex gap-2">
                    <a href="#" class="btn btn-sm rounded-circle d-flex align-items-center justify-content-center"
                       style="width:36px;height:36px;background:rgba(255,255,255,.1);color:#a5b4fc;border:none">
                        <i class="bi bi-twitter-x"></i>
                    </a>
                    <a href="#" class="btn btn-sm rounded-circle d-flex align-items-center justify-content-center"
                       style="width:36px;height:36px;background:rgba(255,255,255,.1);color:#a5b4fc;border:none">
                        <i class="bi bi-facebook"></i>
                    </a>
                    <a href="#" class="btn btn-sm rounded-circle d-flex align-items-center justify-content-center"
                       style="width:36px;height:36px;background:rgba(255,255,255,.1);color:#a5b4fc;border:none">
                        <i class="bi bi-instagram"></i>
                    </a>
                </div>
            </div>

            {# Navigation column #}
            <div class="col-lg-2 col-md-3 col-6">
                <h6 class="text-white fw-bold mb-3 text-uppercase" style="letter-spacing:.08em;font-size:.75rem">Navigation</h6>
                <ul class="list-unstyled mb-0" style="font-size:.9rem">
                    <li class="mb-2">
                        <a href="{{ path('app_home') }}" class="text-decoration-none d-flex align-items-center gap-2"
                           style="color:#a5b4fc;transition:color .2s"
                           onmouseover="this.style.color='#fff'" onmouseout="this.style.color='#a5b4fc'">
                            <i class="bi bi-house-fill" style="font-size:.7rem"></i>Home
                        </a>
                    </li>
                    <li class="mb-2">
                        <a href="{{ path('app_events') }}" class="text-decoration-none d-flex align-items-center gap-2"
                           style="color:#a5b4fc;transition:color .2s"
                           onmouseover="this.style.color='#fff'" onmouseout="this.style.color='#a5b4fc'">
                            <i class="bi bi-grid-fill" style="font-size:.7rem"></i>Events
                        </a>
                    </li>
                    {% if is_granted('ROLE_ADMIN') %}
                    <li class="mb-2">
                        <a href="{{ path('app_admin_dashboard') }}" class="text-decoration-none d-flex align-items-center gap-2"
                           style="color:#a5b4fc;transition:color .2s"
                           onmouseover="this.style.color='#fff'" onmouseout="this.style.color='#a5b4fc'">
                            <i class="bi bi-speedometer2" style="font-size:.7rem"></i>Admin Dashboard
                        </a>
                    </li>
                    {% else %}
                    <li class="mb-2">
                        <a href="{{ path('app_admin_login') }}" class="text-decoration-none d-flex align-items-center gap-2"
                           style="color:#a5b4fc;transition:color .2s"
                           onmouseover="this.style.color='#fff'" onmouseout="this.style.color='#a5b4fc'">
                            <i class="bi bi-shield-lock" style="font-size:.7rem"></i>Admin
                        </a>
                    </li>
                    {% endif %}
                </ul>
            </div>

            {# Contact column #}
            <div class="col-lg-3 col-md-3 col-6">
                <h6 class="text-white fw-bold mb-3 text-uppercase" style="letter-spacing:.08em;font-size:.75rem">Contact</h6>
                <ul class="list-unstyled mb-0" style="font-size:.9rem">
                    <li class="mb-2 d-flex align-items-center gap-2">
                        <i class="bi bi-envelope-fill flex-shrink-0" style="color:#6366f1"></i>
                        <span>contact@eventhub.com</span>
                    </li>
                    <li class="mb-2 d-flex align-items-center gap-2">
                        <i class="bi bi-telephone-fill flex-shrink-0" style="color:#6366f1"></i>
                        <span>+1 (555) 000-0000</span>
                    </li>
                    <li class="d-flex align-items-center gap-2">
                        <i class="bi bi-geo-alt-fill flex-shrink-0" style="color:#6366f1"></i>
                        <span>123 Event Street, City</span>
                    </li>
                </ul>
            </div>

            {# Newsletter column #}
            <div class="col-lg-3 col-md-6">
                <h6 class="text-white fw-bold mb-3 text-uppercase" style="letter-spacing:.08em;font-size:.75rem">Stay Updated</h6>
                <p class="mb-3" style="font-size:.85rem">Get notified about new events and updates.</p>
                <div class="input-group">
                    <input type="email" class="form-control border-0 bg-white bg-opacity-10 text-white"
                           placeholder="your@email.com"
                           style="border-radius:8px 0 0 8px;font-size:.85rem">
                    <button class="btn btn-primary px-3" type="button" style="border-radius:0 8px 8px 0">
                        <i class="bi bi-send-fill"></i>
                    </button>
                </div>
            </div>
        </div>
    </div>

    {# Bottom bar #}
    <div style="border-top:1px solid rgba(255,255,255,.1)">
        <div class="container py-3">
            <div class="d-flex flex-wrap justify-content-between align-items-center gap-2" style="font-size:.85rem">
                <span>&copy; {{ "now"|date("Y") }} EventHub. All rights reserved.</span>
                <div class="d-flex gap-3">
                    <a href="#" class="text-decoration-none" style="color:#a5b4fc">Privacy Policy</a>
                    <a href="#" class="text-decoration-none" style="color:#a5b4fc">Terms of Service</a>
                </div>
            </div>
        </div>
    </div>
</footer>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
{% block javascripts %}{% endblock %}
</body>
</html>
