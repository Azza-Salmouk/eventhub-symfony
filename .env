# In all environments, the following files are loaded if they exist,
# the latter taking precedence over the former:
#
#  * .env                contains default values for the environment variables needed by the app
#  * .env.local          uncommitted file with local overrides
#  * .env.$APP_ENV       committed environment-specific defaults
#  * .env.$APP_ENV.local uncommitted environment-specific overrides
#
# Real environment variables win over .env files.
#
# ⚠️  DO NOT PUT REAL SECRETS IN THIS FILE — use .env.local instead.
#     .env.local is in .gitignore and will never be committed.
#     Copy .env.example to .env.local and fill in your real values.

###> symfony/framework-bundle ###
APP_ENV=dev
# Change this in .env.local — generate with: php -r "echo bin2hex(random_bytes(16));"
APP_SECRET=change_me_generate_with_bin2hex_random_bytes_16
APP_SHARE_DIR=var/share
###< symfony/framework-bundle ###

###> symfony/routing ###
DEFAULT_URI=http://localhost
###< symfony/routing ###

###> doctrine/doctrine-bundle ###
# Local dev (XAMPP): mysql://root:@127.0.0.1:3306/event_project_db?serverVersion=8.0
# Docker:            mysql://eventhub:eventhub_pass@mysql:3306/eventhub_db?serverVersion=8.0&charset=utf8mb4
DATABASE_URL="mysql://eventhub:eventhub_pass@mysql:3306/eventhub_db?serverVersion=8.0&charset=utf8mb4"
###< doctrine/doctrine-bundle ###

###> symfony/messenger ###
MESSENGER_TRANSPORT_DSN=doctrine://default?auto_setup=0
###< symfony/messenger ###

###> symfony/mailer ###
# null://null  → discard all emails (safe default, no SMTP needed)
# Set a real DSN in .env.local to actually send emails.
# See .env.example for Gmail and Mailtrap examples.
MAILER_DSN=null://null
MAILER_FROM_EMAIL=noreply@eventhub.com
MAILER_FROM_NAME=EventHub
###< symfony/mailer ###

###> lexik/jwt-authentication-bundle ###
JWT_SECRET_KEY=%kernel.project_dir%/config/jwt/private.pem
JWT_PUBLIC_KEY=%kernel.project_dir%/config/jwt/public.pem
# Change this in .env.local — use any strong random string
JWT_PASSPHRASE=change_me_use_strong_random_passphrase
###< lexik/jwt-authentication-bundle ###
